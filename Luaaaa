-- Kunin ang nilagay na key ng buyer
local inputKey = _G.PremiumKey

if not inputKey or inputKey == "" then
    error("🔴 Walang nilagay na key sa _G.PremiumKey!")
    return
end

-- LINK NG DATABASE MO (Palitan mo ng iyong totoong username at repo name)
local DATABASE_URL = "https://github.com/jakesales1235-lang/Script2.0-key-systemed/blob/main/Source2.%200"
-- LINK NG SCRAMBLED SCRIPT MO
local SOURCE_URL = "https://github.com/jakesales1235-lang/Keys/blob/main/Lua.%20Source%20%C3%97%2B1000"

-- I-check kung active ang key sa internet
local success, result = pcall(function() return game:HttpGet(DATABASE_URL) end)

if success and result and string.find(result, inputKey) then
    print("✅ Key Verified! Loading script...")
    -- Kapag tama ang key, i-download at patakbuhin ang main script
    local mainScript = game:HttpGet(SOURCE_URL)
    loadstring(mainScript)()
else
    error("🔴 Invalid o Expired na Premium Key!")
end
